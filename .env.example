# SPARK Quality — environment template.
# Copy to `.env` (gitignored) and fill in the values that apply to your setup.
# See CLAUDE.md → "Environment variables" for the full list and what each one unlocks.

# === REQUIRED to boot the server ===

# HS256 signing key for the app_session_id cookie. Must be at least 32 chars.
JWT_SECRET=replace-me-with-a-long-random-string-of-at-least-32-characters

# Manus OAuth project id (also exposed to the client at build time).
VITE_APP_ID=your-manus-project-id

# Manus OAuth server. Login flow cannot complete without this.
OAUTH_SERVER_URL=https://your-manus-oauth-server.example.com

# Manus OAuth portal URL the client redirects to when JWT is missing/expired.
VITE_OAUTH_PORTAL_URL=https://your-manus-oauth-portal.example.com

# === REQUIRED for any flow that persists data ===
# Without this, the server still starts but reports.save / clients.create /
# bulkUpsertClients will throw. The dashboard returns empty results.
# Format: mysql://user:password@host:3306/spark_quality
DATABASE_URL=mysql://user:password@localhost:3306/spark_quality

# === Strongly recommended ===

# Manus openId that should automatically receive role=admin + isSuperAdmin=true
# the first time they sign in. Without this, no super-admin exists.
OWNER_OPEN_ID=your-manus-open-id

# Comma- or semicolon-separated list of additional super-admin emails
# (lower-cased on compare). Defaults to anathemell@gmail.com for legacy compat.
SUPER_ADMIN_EMAILS=anathemell@gmail.com,you@example.com

# Forge proxy used for LLM (ai.composeMessage), file storage (presigned URLs),
# and the notifyOwner notification service. Without these, those features
# return template fallbacks or no-ops; the rest of the app still works.
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# === Optional ===

# Resend API key. Powers contact-form delivery and workspaces.invite emails.
# When missing, the DB row is still created — only the outbound email is skipped.
RESEND_API_KEY=re_xxxxxxxxxxxx

# iCount billing integration. When unset, billing.requestCheckout falls back
# to a manual flow that notifies SPARK staff via Manus + emails Anat.
ICOUNT_API_KEY=
ICOUNT_COMPANY_ID=

# Preferred port (the server falls through to the next free one if taken).
PORT=3000

# Node env. Set to "production" only for the production build.
NODE_ENV=development
